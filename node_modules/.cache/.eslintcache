bleWarningCount":0},{"filePath":"35","messages":"36","suppressedMessages":"37","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"38","messages":"39","suppressedMessages":"40","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"41","messages":"42","suppressedMessages":"43","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/home/super/Documents/Wingman/bcaral.github.io/src/index.js",[],[],"/home/super/Documents/Wingman/bcaral.github.io/src/reportWebVitals.js",[],[],"/home/super/Documents/Wingman/bcaral.github.io/src/pages/DiscordBot.js",["44","45","46"],[],"import React from 'react';\nimport { BrowserRouter as Router, Routes, Route, Link } from 'react-router-dom';\n\nimport NavBar from '../components/NavBar';\n\n\nimport banner from '../resources/wingman-banner-2.png';\n\nimport '../App.css';\n\n\nconst DiscordBot = () => {\n  return (\n<div>\n        <NavBar />\n        <div className=\"App\">\n          <img src={banner} alt=\"Banner\" className=\"App-banner\" />\n\n\n          <div style={{\n            paddingTop: '10px', position: 'absolute',\n            top: '50%',\n            left: '50%',\n            transform: 'translate(-50%, -50%)',\n            color: 'white',\n            fontSize: '32px',\n            zIndex: '1',\n          }}>\n\n            <p>\n\n              The Ultimate Companion for Apex Legends Enthusiasts <br />\n              Try Our Exclusive<br />\n            </p>\n            <div style={{ paddingTop: '20px' }}>\n            <Link\n              to=\"/discordbot\"\n              style={{\n                color: '#CCCCCC',\n                textDecoration: 'none',\n                fontWeight: 'bold',\n                textShadow: '2px 2px 4px rgba(0, 0, 0, 0.5)',\n              }}\n            >\n              Discord Bot\n            </Link>{' '}\n              or{' '}\n              <Link\n                to=\"/alexaskill\"\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                style={{ \n                  color: '#CCCCCC',\n                  textDecoration: 'none', // Remove the underline\n                  fontWeight: 'bold',\n                  textShadow: '2px 2px 4px rgba(0, 0, 0, 0.5)',\n                }}\n              >\n                Alexa Skill\n              </Link>\n            </div>\n          </div>\n\n        </div>\n\n      </div>\n  );\n};\n\nexport default DiscordBot;","/home/super/Documents/Wingman/bcaral.github.io/src/pages/Home.js",["47","48","49","50","51","52"],[],"import React from 'react';\nimport { BrowserRouter as Router, Routes, Route, Link } from 'react-router-dom';\n\nimport NavBar from '../components/NavBar';\nimport DiscordBotInfo from '../components/DiscordBotInfo';\nimport NemesisBotInfo from '../components/NemesisBotInfo';\nimport AlexaSkillInfo from '../components/AlexaSkillInfo';\nimport apex_bullet from '../resources/apex-legends-symbol_2.png';\nimport apex_ss_map from '../resources/WINGMAN_SS_1.png'\nimport apex_ss_status from '../resources/wingman_nemesis_discord_map.png'\n\n\nimport banner from '../resources/wingman-banner-2.png';\n\nimport '../App.css';\n\n\nconst Home = () => {\n\n  const discordLink = 'https://discord.com/oauth2/authorize?client_id=951349733211930654&permissions=19327446016&scope=bot';\n  const AlexaLink = 'https://www.amazon.com/CB-WINGMAN-Apex-Legends-Info/dp/B0BTNZSF5N';\n\n\n  return (\n    <div style={{ background: '#332A2B', minHeight: '100vh', color: 'white' }}>\n      <NavBar />\n      <div className=\"App\">\n        <img src={banner} alt=\"Banner\" className=\"App-banner\" />\n\n\n        <div style={{\n          paddingTop: '10px', position: 'absolute',\n          bottom: '20%',\n          left: '50%',\n          transform: 'translate(-50%, -50%)',\n          color: 'white',\n          fontSize: '32px',\n          zIndex: '1',\n        }}>\n\n          <     img src={apex_bullet} alt=\"Logo\" style={{ width: '80px' }} />\n\n\n          <div style={{ paddingTop: '30px' }}>\n            Try Our Exclusive<br />\n          </div>\n\n          <div style={{ paddingTop: '10px' }}>\n            <a\n              href='#section-main'\n              style={{\n                color: '#CCCCCC',\n                textDecoration: 'none',\n                fontWeight: 'bold',\n                textShadow: '2px 2px 4px rgba(0, 0, 0, 0.5)',\n              }}\n            >\n              Discord Bot\n            </a>{' '}\n            or{' '}\n            <a\n              href='#section-main'\n              target=\"_blank\"\n              rel=\"noopener noreferrer\"\n              style={{\n                color: '#CCCCCC',\n                textDecoration: 'none', // Remove the underline\n                fontWeight: 'bold',\n                textShadow: '2px 2px 4px rgba(0, 0, 0, 0.5)',\n              }}\n            >\n              Alexa Skill\n            </a>\n          </div>\n\n        </div>\n\n        <div id='section-main' style={{  display: 'flex', justifyContent: 'center', fontSize: '30px', paddingTop: '30px' }}>\n          The Ultimate Companion for Apex Legends Enthusiasts\n        </div>\n        <div style={{ display: 'flex', justifyContent: 'center', padding: '30px', fontSize: '18px' }}>\n          WINGMAN truly proves to be an indispensable companion for all Apex Legends enthusiasts, <br />\n          streamlining information and enhancing the overall gaming experience. <br /></div>\n\n\n\n        <div style={{ display: 'flex', justifyContent: 'center', width: '100%', background: '#4D3F41', padding: '30px' }}>\n          <div style={{ marginLeft: '90px' }}>\n            <DiscordBotInfo />\n          </div>\n          <div style={{ marginRight: '90px' }}>\n            <AlexaSkillInfo />\n          </div>\n        </div>\n\n\n\n        <div style={{ paddingTop: '30px', fontSize: '22px', paddingBottom: '10px' }}>\n          <div style={{ fontSize: '30px', fontWeight: 'bold' }}>Featuring  </div>\n          <div style={{ paddingTop: '30px ', fontSize: '18px', display: 'flex', justifyContent: 'center' }}>\n            <ul style={{ listStyleType: 'none  ', paddingLeft: '20px' }}>\n              <li>\n                <img src={apex_bullet} alt=\"Logo\" style={{ width: '20px', verticalAlign: 'top' }} />\n                <span style={{ paddingLeft: '10px' }}>Up-to-date player statistics.</span>\n              </li>\n\n              <li style={{ paddingTop: '5px' }}>\n                <img src={apex_bullet} alt=\"Logo\" style={{ width: '20px', verticalAlign: 'top' }} />\n                <span style={{ paddingLeft: '10px' }}>Real-time status updates to stay informed about the current map and its duration.</span>\n              </li>\n\n              <li style={{ paddingTop: '5px' }}>\n                <img src={apex_bullet} alt=\"Logo\" style={{ width: '20px', verticalAlign: 'top' }} />\n                <span style={{ paddingLeft: '10px' }}>Random drop locations for added excitement.</span>\n              </li>\n              <li style={{ paddingTop: '5px' }}>\n                <img src={apex_bullet} alt=\"Logo\" style={{ width: '20px', verticalAlign: 'top' }} />\n                <span style={{ paddingLeft: '10px' }}>Stay informed about the current craft rotation items.</span>\n              </li>\n              <li style={{ paddingTop: '5px' }}>\n                <img src={apex_bullet} alt=\"Logo\" style={{ width: '20px', verticalAlign: 'top' }} />\n                <span style={{ paddingLeft: '10px' }}>Get latest news and status information, ensuring you never miss important updates.</span>\n              </li>\n              <li style={{ paddingTop: '5px' }}>\n                <img src={apex_bullet} alt=\"Logo\" style={{ width: '20px', verticalAlign: 'top' }} />\n                <span style={{ paddingLeft: '10px' }}>Challenges that offer random legend and weapon combinations.</span>\n              </li>\n            </ul>\n          </div>\n        </div>\n\n\n        <div style={{ marginTop: '40px', fontSize: '22px', padding: '20px', background: '#4D3F41', }}>\n          For real time Ranked Map rotation status try out <strong>NEMESIS</strong>,<br /> another helpful Discord bot that works alongside WINGMAN. <br />\n        </div>\n\n        <div style={{ display: 'flex', justifyContent: 'center', width: '100%', background: '#4D3F41', padding: '30px' }}>\n          <div >\n            <NemesisBotInfo />\n          </div>\n        </div>\n\n        <div style={{ fontSize: '30px', fontWeight: 'bold', paddingTop:'20px' }}>About  </div>\n\n        <div style={{ display: 'flex', justifyContent: 'center', width: '100%', padding: '40px', borderBottom: '1px solid #4D3F41' }}>\n       \n          <div style={{ marginLeft: '90px', width:'40%'  }}>\n          <img src={apex_ss_status} alt=\"Logo\" style={{verticalAlign: 'top' }} />\n          </div>\n          <div style={{ marginRight: '90px', width:'40%' }}>\n          Real time status for map rotation including the current map and the minutes remaining.<br /><br />\n            WINGMAN provides pubs map information <br/> NEMESIS provides ranked map information.<br/> Add them both to your server to provide the full experience.\n          \n          </div>\n          </div>\n\n          <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', width: '100%', padding: '30px' }}>\n  <div style={{ marginLeft: '90px', width: '40%' }}>\n    Type '/map' to find out the current map, its duration and what map will be next for all game modes including pubs, ranked or LTM (Limited Time Mode).\n  </div>\n  <div style={{ marginRight: '90px', width: '40%' }}>\n    <img src={apex_ss_map} alt=\"Logo\" style={{ verticalAlign: 'top' }} />\n  </div>\n</div>\n\n\n\n      </div>\n\n    </div>\n  );\n};\n\nexport default Home;","/home/super/Documents/Wingman/bcaral.github.io/src/components/DiscordBotInfo.js",[],[],"/home/super/Documents/Wingman/bcaral.github.io/src/components/NemesisBotInfo.js",[],[],"/home/super/Documents/Wingman/bcaral.github.io/src/components/NavBar.js",[],[],"/home/super/Documents/Wingman/bcaral.github.io/src/components/AlexaSkillInfo.js",[],[],{"ruleId":"53","severity":1,"message":"54","line":2,"column":27,"nodeType":"55","messageId":"56","endLine":2,"endColumn":33},{"ruleId":"53","severity":1,"message":"57","line":2,"column":35,"nodeType":"55","messageId":"56","endLine":2,"endColumn":41},{"ruleId":"53","severity":1,"message":"58","line":2,"column":43,"nodeType":"55","messageId":"56","endLine":2,"endColumn":48},{"ruleId":"53","severity":1,"message":"54","line":2,"column":27,"nodeType":"55","messageId":"56","endLine":2,"endColumn":33},{"ruleId":"53","severity":1,"message":"57","line":2,"column":35,"nodeType":"55","messageId":"56","endLine":2,"endColumn":41},{"ruleId":"53","severity":1,"message":"58","line":2,"column":43,"nodeType":"55","messageId":"56","endLine":2,"endColumn":48},{"ruleId":"53","severity":1,"message":"59","line":2,"column":50,"nodeType":"55","messageId":"56","endLine":2,"endColumn":54},{"ruleId":"53","severity":1,"message":"60","line":20,"column":9,"nodeType":"55","messageId":"56","endLine":20,"endColumn":20},{"ruleId":"53","severity":1,"message":"61","line":21,"column":9,"nodeType":"55","messageId":"56","endLine":21,"endColumn":18},"no-unused-vars","'Router' is defined but never used.","Identifier","unusedVar","'Routes' is defined but never used.","'Route' is defined but never used.","'Link' is defined but never used.","'discordLink' is assigned a value but never used.","'AlexaLink' is assigned a value but never used."]